        "import pandas as pd\n",
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "import plotly.express as px\n",
        "\n",
        "def generar_dashboard_y_exportar(df):\n",
        "    \"\"\"\n",
        "    Pipeline de visualización gerencial y persistencia de datos.\n",
        "    Integra gráficos estadísticos y exporta los resultados para interoperabilidad.\n",
        "    \"\"\"\n",
        "    # 1. Visualizaciones Exploratorias (Seaborn)\n",
        "    plt.figure(figsize=(14, 6))\n",
        "\n",
        "    # Matriz de Correlación (Diagnóstico de relación pasajeros/retraso)\n",
        "    plt.subplot(1, 2, 1)\n",
        "    columnas = ['tiempo_viaje_min', 'retraso_min', 'pasajeros_reportados']\n",
        "    sns.heatmap(df[columnas].corr(), annot=True, cmap='coolwarm', fmt=\".3f\")\n",
        "    plt.title(\"Matriz de Correlación de Pearson\")\n",
        "\n",
        "    # Histograma de distribución de tiempos\n",
        "    plt.subplot(1, 2, 2)\n",
        "    sns.histplot(df['tiempo_viaje_min'], kde=True, color='teal')\n",
        "    plt.title(\"Distribución de Tiempos de Viaje\")\n",
        "    plt.show()\n",
        "\n",
        "    # 2. Dashboard Interactivo (Plotly)\n",
        "    resumen = df.groupby(['ruta', 'turno'])['retraso_min'].mean().reset_index()\n",
        "    fig = px.bar(resumen, x='ruta', y='retraso_min', color='turno', barmode='group',\n",
        "                 title=\"Retrasos Promedio: Ruta y Turno\")\n",
        "    fig.show()\n",
        "\n",
        "    # 3. Exportación para interoperabilidad operacional\n",
        "    df.to_csv(\"moviciudad_procesado.csv\", index=False)\n",
        "    df.to_excel(\"moviciudad_reporte_gerencial.xlsx\", index=False)\n",
        "    print(\"Exportación exitosa: Datos estructurados listos para gestión.\")\n",
        "\n",
        "# Ejecución\n",
        "generar_dashboard_y_exportar(df_final) # Se invoca tras la limpieza\n",
        "generar_dashboard_y_exportar(df_final)"
