        "import pandas as pd\n",
        "\n",
        "def procesar_datos_y_exportar(archivo_entrada):\n",
        "    \"\"\"\n",
        "    Pipeline de procesamiento integrado.\n",
        "    Entrada: Ruta del CSV bruto.\n",
        "    Salida: Dataframe limpio y exportación a formatos estándar.\n",
        "    \"\"\"\n",
        "    # Carga de datos\n",
        "    df = pd.read_csv(archivo_entrada)\n",
        "\n",
        "    # Convert 'tiempo_viaje_min' to numeric, handling potential string issues (like commas)\n",
        "    df['tiempo_viaje_min'] = df['tiempo_viaje_min'].astype(str).str.replace(',', '.', regex=False).astype(float)\n",
        "\n",
        "    # Limpieza: Eliminación de nulos críticos y estandarización\n",
        "    # Se utiliza una técnica de imputación por mediana para no sesgar la varianza\n",
        "    df['tiempo_viaje_min'] = df.groupby(['ruta'])['tiempo_viaje_min'].transform(lambda x: x.fillna(x.median()))\n",
        "\n",
        "    # Persistencia: Exportación para interoperabilidad\n",
        "    df.to_csv(\"datos_limpios.csv\", index=False)\n",
        "    df.to_excel(\"datos_limpios.xlsx\", index=False)\n",
        "\n",
        "    return df\n",
