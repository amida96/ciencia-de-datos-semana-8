        "import pandas as pd\n",
        "\n",
        "def procesar_dataset_moviciudad(ruta_csv):\n",
        "    \"\"\"\n",
        "    Pipeline reproducible para la extracción y sanitización de datos operativos.\n",
        "    \"\"\"\n",
        "    # 1. Ingesta\n",
        "    df = pd.read_csv(ruta_csv)\n",
        "\n",
        "    # 2. Estandarización de nombres (Defensiva)\n",
        "    df.rename(columns={'capacidad': 'capacidad_bus'}, inplace=True, errors='ignore')\n",
        "\n",
        "    # 3. Transformación Temporal (Limpieza)\n",
        "    df['fecha_registro'] = pd.to_datetime(df['fecha_registro'], errors='coerce')\n",
        "\n",
        "    # Convert 'tiempo_viaje_min' to numeric, handling potential string issues (like commas)\n",
        "    df['tiempo_viaje_min'] = df['tiempo_viaje_min'].astype(str).str.replace(',', '.', regex=False).astype(float)\n",
        "\n",
        "    # 4. Imputación condicionada (Lógica de negocio por ruta y turno)\n",
        "    df['tiempo_viaje_min'] = df.groupby(['ruta', 'turno'])['tiempo_viaje_min'].transform(lambda x: x.fillna(x.median()))\n",
        "\n",
        "    # 5. Estructuración y tipado (Limpieza de caracteres extraños)\n",
        "    df['retraso_min'] = pd.to_numeric(df['retraso_min'].astype(str).str.replace(' min', '', regex=False), errors='coerce')\n",
        "\n",
        "    # 6. Depuración final para viabilidad de modelado\n",
        "    df_limpio = df.dropna(subset=['retraso_min', 'pasajeros_reportados'])\n",
        "\n",
        "    return df_limpio\n",
        "\n",
        "# Ejecución\n",
        "# Using the correct path from the 'ruta_datos' variable, assuming the file is in the root of My Drive\n",
        "ruta_datos = \"/content/drive/MyDrive/Ciencia de datos/moviciudad_operaciones_bruto_SET_A (1).csv\"\n",
        "df_final = procesar_dataset_moviciudad(ruta_datos)\n",
        "print(f\"Dataset estructurado. Registros finales: {len(df_final)}\")"
